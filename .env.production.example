# .env.production.example — copy to `.env.production` and fill in real values.
#   cp .env.production.example .env.production
# NEVER commit the filled-in .env.production (it holds secrets). This .example
# is safe to commit (placeholders only).
#
# In Docker, REDIS_* are overridden by docker-compose.yml to point at the redis
# service — you do NOT need to set them here for the compose stack.

# ── Core ──
NODE_ENV=production
PORT=3000
# Public URL of THIS backend (used in links / CORS). e.g. https://api.yourdomain.com
SERVER_URL=https://api.yourdomain.com
API_VERSION=v1
# THREAD_NUM=0 => use all CPU cores.
THREAD_NUM=0
# Max upload size (MB) — gates ALL request bodies incl. media. 25 matches the app.
UPLOAD_MAX_MB=25

# ── MongoDB (Atlas — stays cloud) ──
# IMPORTANT: keep the /test database in the path (real data lives in DB "test").
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/test?appName=Cluster0

# ── Redis ── (Docker compose sets these to the redis service automatically;
#             only fill these if running OUTSIDE compose / against external Redis.)
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── JWT secrets (REQUIRED — the server refuses to start without these) ──
# Generate strong random values, e.g.:  openssl rand -hex 48
JWT_SECRET=CHANGE_ME_long_random_hex
JWT_REFRESH_SECRET=CHANGE_ME_long_random_hex
TEMP_JWT_SECRET=CHANGE_ME_long_random_hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
SESSION_SECRET=CHANGE_ME_random

# ── CORS ── (comma-separated allowed origins for the app / web)
CORS_ORIGIN=https://yourdomain.com
CORS_CREDENTIALS=true

# ── LiveKit (voice/video calling) ── from cloud.livekit.io → Project → Keys
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=CHANGE_ME_livekit_secret
LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# ── Firebase (push notifications) ──
# Either point at a mounted service-account JSON file...
# FIREBASE_SERVICE_ACCOUNT_PATH=/app/secrets/firebase.json
# ...or supply the three fields inline (\n-escaped private key, as in dev .env):
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Email (Brevo) — OTP / verification ──
EMAIL_API_KEY=xkeysib-CHANGE_ME
YOUR_EMAIL=you@example.com
YOUR_EMAIL_APP_PASSWORD=CHANGE_ME
YOUR_EMAIL_DISPLAY_NAME=Pulse App

# ── Cloudinary (media uploads) ──
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

# ── Tenor (GIFs) ──
TENOR_API_KEY=CHANGE_ME
TENOR_CLIENT_KEY=pulse_app

# ── Twilio (SMS OTP — optional) ──
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# ── Feature flags ──
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PHONE_VERIFICATION=false
ENABLE_BACKGROUND_JOBS=false
LOG_LEVEL=info
