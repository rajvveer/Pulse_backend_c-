# ──────────────────────────────────────────────────────────────────────────
# Pulse Backend (C++) — environment template. Copy to .env and fill in.
# Mirrors the Node backend's env contract 1:1 so the same .env works for both.
# ──────────────────────────────────────────────────────────────────────────

# ===== Core =====
NODE_ENV=development
PORT=3000
API_VERSION=v1
SERVER_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ===== Required secrets (app refuses to boot in production without these) =====
JWT_SECRET=
JWT_REFRESH_SECRET=
TEMP_JWT_SECRET=
SESSION_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ===== Database =====
MONGO_URI=mongodb://localhost:27017/pulse
MONGO_TEST_URI=mongodb://localhost:27017/pulse_test
MONGO_OPTIONS_MAX_POOL_SIZE=50
MONGO_OPTIONS_MIN_POOL_SIZE=5
MONGO_OPTIONS_SERVER_SELECTION_TIMEOUT_MS=5000

# ===== Redis (required in production) =====
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAX_RETRIES=3

# ===== HTTP server =====
# Number of Drogon IO worker threads (defaults to hardware concurrency).
THREAD_NUM=0
HTTP_KEEPALIVE_TIMEOUT_MS=65000
HTTP_REQUEST_TIMEOUT_MS=30000
SHUTDOWN_DRAIN_MS=5000
SHUTDOWN_FORCE_MS=30000

# ===== Networking / proxy =====
TRUST_PROXY_HOPS=1
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# ===== Socket.IO compatibility (WebSocket realtime) =====
SOCKET_ENABLE_POLLING=false

# ===== Rate limiting =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_REQUESTS_PER_IP=1000
AUTH_RATE_LIMIT_MAX=100
OTP_RATE_LIMIT_MAX=30
UPLOAD_RATE_LIMIT_MAX=60

# ===== Feed / cache TTLs (seconds) =====
FEED_CANDIDATE_TTL_SEC=30
FEED_PAGE_TTL_SEC=20
FOLLOW_GRAPH_TTL_SEC=60
REEL_CANDIDATE_TTL_SEC=30
TRENDING_HASHTAG_TTL_SEC=600

# ===== Uploads =====
UPLOAD_MAX_MB=25
UPLOAD_MAX_FILES=5
REEL_MAX_MB=80

# ===== Sanitization caps =====
SANITIZE_MAX_DEPTH=12
SANITIZE_MAX_NODES=5000
SANITIZE_MAX_STRING=50000
JSON_BODY_LIMIT=262144

# ===== Background jobs =====
ENABLE_BACKGROUND_JOBS=false

# ===== Email OTP (Brevo) =====
EMAIL_API_KEY=
YOUR_EMAIL=
YOUR_EMAIL_DISPLAY_NAME=Pulse App

# ===== SMS OTP (Twilio) =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
SMS_GLOBAL_DAILY_MAX=5000

# ===== Cloudinary =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=pulse/media

# ===== Firebase (push) =====
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ===== Observability =====
SENTRY_DSN=
LOG_LEVEL=info
INTERNAL_STATUS_KEY=
ENABLE_API_DOCS=false
